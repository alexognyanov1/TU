// Copy this file to config.h and fill in your values.
// config.h is listed in .gitignore and must never be committed.

#pragma once

// ---------------------------------------------------------------------------
// WiFi
// ---------------------------------------------------------------------------
#define WIFI_SSID     "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// ---------------------------------------------------------------------------
// MQTT broker
// ---------------------------------------------------------------------------
#define MQTT_BROKER    "192.168.1.100"   // IP or hostname of your broker
#define MQTT_PORT      1883
#define MQTT_USERNAME  "mqtt_user"       // leave as "" to connect without auth
#define MQTT_PASSWORD  "mqtt_password"

// ---------------------------------------------------------------------------
// MQTT topics  (must match backend config)
// ---------------------------------------------------------------------------
#define MQTT_CLIENT_ID      "esp32_garage"
#define MQTT_COMMAND_TOPIC  "garage/command"
#define MQTT_STATUS_TOPIC   "garage/status"

// ---------------------------------------------------------------------------
// Hardware
// ---------------------------------------------------------------------------
#define MOTOR_PIN             4      // GPIO pin connected to relay IN
#define MOTOR_RUN_DURATION_MS 5000   // how long to energise the relay (ms)
