# Copy this file to .env and fill in your values.

LOGIN_USERNAME=admin
LOGIN_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_string

# MQTT broker connection
#
# Local / dev — plain TCP directly to Mosquitto:
#   MQTT_BROKER=<raspberry-pi-ip>  MQTT_PORT=1883  MQTT_TRANSPORT=tcp  MQTT_TLS=false
#
# Production — WebSocket Secure through nginx:
#   MQTT_BROKER=mqtt.yourdomain.com  MQTT_PORT=443  MQTT_TRANSPORT=websockets  MQTT_TLS=true
#
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_COMMAND_TOPIC=garage/command
MQTT_TRANSPORT=tcp
MQTT_TLS=false
