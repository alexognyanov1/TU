# Copy this file to .env and fill in your values.

LOGIN_USERNAME=admin
LOGIN_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_string

# Shared token the ESP32 uses to authenticate its WebSocket connection.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match the wsToken value saved on the device during setup.
ESP_WS_TOKEN=replace_with_another_long_random_string
